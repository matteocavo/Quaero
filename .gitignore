# Python
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.venv/

# Private / local-only projects
.private/

# Claude Code session settings (local machine only)
.claude/

# IDE workspace files
*.code-workspace

# Agent interaction and internal dev workflow docs
AGENTS.md
WORKFLOW.md
LOOP.md
