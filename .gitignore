# Generated pipeline artifacts (binary, regenerable)
projects/*/raw/
projects/*/staging/
projects/*/integrated/
projects/*/marts/
projects/*/ui_inputs/

# Generated metadata (run-specific, not source)
projects/*/metadata/run_manifest_*.json
projects/*/metadata/*_profile.json
projects/*/metadata/cleaning_summary_*.json
projects/*/metadata/anomaly_report_*.json
projects/*/metadata/analytics_metadata_*.json
projects/*/metadata/dashboard_suggestions_*.json
